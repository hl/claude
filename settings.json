{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(elixir /tmp/*.exs)",
      "Bash(elixir /tmp/**/*.exs)",
      "Bash(cat /tmp/*)",
      "Bash(cat /tmp/**/*)",
      "Bash(say *)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/wrap_bash_silent.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(test(\"\\\\.exs?$\"))' | xargs -I{} mix format \"{}\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "playwright-cli@playwright-cli": true,
    "plugin-dev@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "walkthrough@sona-marketplace": true,
    "doc-ticket-solver@sona-marketplace": true,
    "duckdb-csv@sona-marketplace": true,
    "rules-engine@sona-marketplace": true,
    "rules-output-auditor@sona-marketplace": true,
    "frontend-design@claude-plugins-official": true,
    "code-reviewer@sona-marketplace": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754052688085
  }
}